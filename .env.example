OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# Busca web: auto (reitoria/docs desatualizados) | always | off
WEB_SEARCH_MODE=auto
WEB_SEARCH_MAX_RESULTS=5
UESPI_SITE=https://uespi.br

SIGAA_CURSOS_URL=https://sigaa.uespi.br/sigaa/public/curso/lista.jsf?nivel=G&aba=p-ensino
SIGAA_CACHE_HOURS=24
# Agenda telefônica (diretores de centro/campus) — cache em data/cache/gestao_agenda.json
# GESTAO_CACHE_HOURS=24
SIGAA_SSL_VERIFY=false

# Mensagens de histórico enviadas ao modelo (user+assistant)
CHAT_HISTORY_MAX_MESSAGES=20

# Bloqueio de xingamentos e termos ofensivos (true|false)
MODERATION_ENABLED=true

SIGPROP_PESQUISA_URL=https://sistemas2.uespi.br/sigprop/index_pesquisa.php

REGIMENTO_PDF_URL=https://uespi.br/wp-content/uploads/2021/08/Regimento.pdf
# Opcional — busca mais confiável (https://tavily.com)
# TAVILY_API_KEY=

# --- Melhorias de recuperação (RAG) ---
# Reranking com cross-encoder após busca vetorial
RAG_RERANKER_ENABLED=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-base
# Busca híbrida BM25 + denso (requer reindexar: python -m chatbot.ingest_cli --reset)
RAG_HYBRID_ENABLED=true
RAG_HYBRID_ALPHA=0.5
# Multi-query: reescreve a pergunta em variações (1 chamada extra à OpenAI por pergunta)
RAG_MULTI_QUERY_ENABLED=true
RAG_MULTI_QUERY_COUNT=2
# Pré-carrega reranker, vector store, BM25 e SIGAA ao subir a API
RAG_PRELOAD_ON_STARTUP=true
# Host/porta da API FastAPI (python -m chatbot.api)
# API_HOST=127.0.0.1
# API_PORT=8000
# Token Hugging Face (opcional — evita aviso e acelera download do reranker)
# HF_TOKEN=

# --- Latência: desative para respostas mais rápidas (pequena perda de qualidade) ---
# RAG_MULTI_QUERY_ENABLED=false
# RAG_RERANKER_ENABLED=false
# RAG_HYBRID_ENABLED=false
# RAG_RETRIEVAL_FETCH_K=12
# RAG_RETRIEVAL_K=4

# pinecone | chroma (se PINECONE_API_KEY existir, o padrão é pinecone)
VECTOR_STORE=pinecone

PINECONE_API_KEY=
PINECONE_INDEX_NAME=uespi-docs
PINECONE_NAMESPACE=uespi
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Cria o índice automaticamente na primeira indexação (opcional)
PINECONE_CREATE_INDEX=false
