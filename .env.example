OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# Busca web: auto (reitoria/docs desatualizados) | always | off
WEB_SEARCH_MODE=auto
WEB_SEARCH_MAX_RESULTS=5
UESPI_SITE=https://uespi.br

SIGAA_CURSOS_URL=https://sigaa.uespi.br/sigaa/public/curso/lista.jsf?nivel=G&aba=p-ensino
SIGAA_CACHE_HOURS=24
SIGAA_SSL_VERIFY=false

# Mensagens de histórico enviadas ao modelo (user+assistant)
CHAT_HISTORY_MAX_MESSAGES=20

# Bloqueio de xingamentos e termos ofensivos (true|false)
MODERATION_ENABLED=true

SIGPROP_PESQUISA_URL=https://sistemas2.uespi.br/sigprop/index_pesquisa.php

REGIMENTO_PDF_URL=https://uespi.br/wp-content/uploads/2021/08/Regimento.pdf
# Opcional — busca mais confiável (https://tavily.com)
# TAVILY_API_KEY=

# pinecone | chroma (se PINECONE_API_KEY existir, o padrão é pinecone)
VECTOR_STORE=pinecone

PINECONE_API_KEY=
PINECONE_INDEX_NAME=uespi-docs
PINECONE_NAMESPACE=uespi
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Cria o índice automaticamente na primeira indexação (opcional)
PINECONE_CREATE_INDEX=false
